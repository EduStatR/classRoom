\name{croqui.DBC}
\alias{croqui.DBC}
\title{
Distribuicao aleatoria dos tratamentos no delineamento em blocos completos
}
\description{
Apresenta a distribuicao aleatoria dos tratamentos dentro de cada bloco.
}
\usage{
croqui.DBC(ntrat, nblocos)
}
\arguments{
  \item{ntrat}{numero de tratamentos em teste}
  \item{nblocos}{numero de blocos no experimento}
}
\details{
Permite obter o croqui da distribuicao dos tratamentos nos blocos.

}
\value{Retorna o croqui da distribuicao dos tratamentos nos blocos.


}
\references{
Banzatto, D. A.; Kronka, S. N. Experimentacao Agricola. Jaboticabal: FUNEP.
2006. 237p.
}
